<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:PhoneCamera.Controls"
             x:Class="PhoneCamera.MainPage"
             Shell.NavBarIsVisible="False">

    <Grid>

        <!-- Camera preview: платформенный ImageView, кадры ставятся через SetImageBitmap() -->
        <controls:CameraPreviewView
            x:Name="CameraPreview"
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
            BackgroundColor="Black" />

        <!-- Top overlay: config selector -->
        <VerticalStackLayout VerticalOptions="Start" HorizontalOptions="Fill">

            <!-- Header bar -->
            <Grid BackgroundColor="#CC000000" Padding="16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label x:Name="ConfigLabel"
                       Grid.Column="0"
                       Text="—"
                       TextColor="White"
                       FontSize="15"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
                <Label x:Name="ConfigArrow"
                       Grid.Column="1"
                       Text="▼"
                       TextColor="#AAFFFFFF"
                       FontSize="11"
                       VerticalOptions="Center"
                       Margin="12,0,0,0" />
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnConfigHeaderTapped" />
                </Grid.GestureRecognizers>
            </Grid>

            <!-- Dropdown list -->
            <CollectionView
                x:Name="ConfigList"
                IsVisible="false"
                MaximumHeightRequest="220"
                BackgroundColor="#EE000000"
                SelectionMode="Single"
                SelectionChanged="OnConfigSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="controls:CameraConfig">
                        <Grid Padding="20,12">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="Transparent" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="#55FFFFFF" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                            <Label Text="{Binding DisplayName}"
                                   TextColor="White"
                                   FontSize="14" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

        <!-- Bottom overlay: controls bar -->
        <Grid VerticalOptions="End" BackgroundColor="#CC000000" Padding="16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="4">
                <Label x:Name="ConnectionLabel"
                       Text="Не подключено"
                       TextColor="#CCFFFFFF"
                       FontSize="13" />
                <Label x:Name="StatusLabel"
                       Text="Press Start"
                       TextColor="#CCFFFFFF"
                       FontSize="13" />
                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                    <CheckBox x:Name="LockCheckBox"
                              CheckedChanged="OnLockCheckedChanged"
                              Color="White" />
                    <Label Text="Зафиксировать"
                           TextColor="White"
                           FontSize="13"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                    <CheckBox x:Name="H264CheckBox"
                              CheckedChanged="OnH264CheckedChanged"
                              Color="White" />
                    <Label Text="H.264 (60 fps стрим)"
                           TextColor="White"
                           FontSize="13"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="8">
                <Button x:Name="ConnectBtn"
                        Text="Подключиться"
                        Clicked="OnConnectClicked"
                        FontSize="13"
                        Padding="14,6" />
                <Button x:Name="StartStopBtn"
                        Text="Start"
                        Clicked="OnStartStopClicked"
                        FontSize="15"
                        Padding="20,8" />
            </VerticalStackLayout>
        </Grid>

    </Grid>

</ContentPage>
