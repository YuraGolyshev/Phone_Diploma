<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:PhoneCamera.Controls"
             x:Class="PhoneCamera.MainPage"
             Shell.NavBarIsVisible="False"
             Padding="0">

    <ContentPage.Resources>
        <!-- Общий шаблон элемента списка: Label, привязка к свойству DisplayName.
             Без x:DataType — общий для разных типов (ResolutionOption / FpsOption / FormatOption). -->
        <DataTemplate x:Key="DropdownItemTemplate">
            <Grid Padding="20,12">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#55FFFFFF" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
                <Label Text="{Binding DisplayName}"
                       TextColor="White"
                       FontSize="14" />
            </Grid>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid IgnoreSafeArea="True">

        <!-- Camera preview: платформенный ImageView, кадры ставятся через SetImageBitmap() -->
        <controls:CameraPreviewView
            x:Name="CameraPreview"
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
            BackgroundColor="Black" />

        <!-- Status bar backdrop: перекрывает зону системной шторки тёмным цветом
             #CC000000, чтобы прозрачная системная шторка визуально была окрашена
             в цвет наших шторок. Высота задаётся динамически из code-behind
             (MainActivity.StatusBarHeightDp). -->
        <BoxView x:Name="StatusBarBackdrop"
                 VerticalOptions="Start"
                 HorizontalOptions="Fill"
                 HeightRequest="28"
                 BackgroundColor="#CC000000"
                 InputTransparent="True" />

        <!-- Top overlay: три отдельные шторки (Разрешение / FPS / Формат).
             Grid с переменной раскладкой:
               • portrait  — 1 column × 3 rows (друг под другом, full-width)
               • landscape — 3 columns × 1 row (в ряд, по 1/3 ширины каждый)
             Раскладка перестраивается из code-behind в OnSizeAllocated →
             ApplyTopOverlayLayout. Каждый «слот» — VerticalStackLayout с
             header + dropdown под ним. -->
        <Grid x:Name="TopOverlayLayout"
              VerticalOptions="Start"
              HorizontalOptions="Fill">

            <!-- ── Шторка 1: Разрешение ─────────────────────────────────── -->
            <VerticalStackLayout x:Name="ResolutionSlot">
                <Grid BackgroundColor="#CC000000" Padding="16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label x:Name="ResolutionLabel"
                           Grid.Column="0"
                           Text="Разрешение: —"
                           TextColor="White"
                           FontSize="15"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           LineBreakMode="TailTruncation" />
                    <Label x:Name="ResolutionArrow"
                           Grid.Column="1"
                           Text="▼"
                           TextColor="#AAFFFFFF"
                           FontSize="11"
                           VerticalOptions="Center"
                           Margin="12,0,0,0" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnResolutionHeaderTapped" />
                    </Grid.GestureRecognizers>
                </Grid>
                <CollectionView x:Name="ResolutionList"
                                IsVisible="false"
                                MaximumHeightRequest="220"
                                BackgroundColor="#EE000000"
                                SelectionMode="Single"
                                SelectionChanged="OnResolutionSelected"
                                ItemTemplate="{StaticResource DropdownItemTemplate}" />
            </VerticalStackLayout>

            <!-- ── Шторка 2: FPS ────────────────────────────────────────── -->
            <VerticalStackLayout x:Name="FpsSlot">
                <Grid BackgroundColor="#CC000000" Padding="16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label x:Name="FpsLabel"
                           Grid.Column="0"
                           Text="FPS: —"
                           TextColor="White"
                           FontSize="15"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           LineBreakMode="TailTruncation" />
                    <Label x:Name="FpsArrow"
                           Grid.Column="1"
                           Text="▼"
                           TextColor="#AAFFFFFF"
                           FontSize="11"
                           VerticalOptions="Center"
                           Margin="12,0,0,0" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFpsHeaderTapped" />
                    </Grid.GestureRecognizers>
                </Grid>
                <CollectionView x:Name="FpsList"
                                IsVisible="false"
                                MaximumHeightRequest="220"
                                BackgroundColor="#EE000000"
                                SelectionMode="Single"
                                SelectionChanged="OnFpsSelected"
                                ItemTemplate="{StaticResource DropdownItemTemplate}" />
            </VerticalStackLayout>

            <!-- ── Кнопка настроек ─────────────────────────────────────────
                 Одна ячейка с фоном #CC000000 (как у заголовков шторок).
                 Иконка с VerticalOptions=Start + Padding=16,10 — пришпилена
                 к верху, не съезжает при растяжении slot'а в portrait. -->
            <Grid x:Name="SettingsSlot"
                  BackgroundColor="#CC000000"
                  MinimumWidthRequest="44">
                <Label x:Name="SettingsIcon"
                       Text="⛭"
                       TextColor="White"
                       FontSize="15"
                       FontAttributes="Bold"
                       Padding="16,10"
                       HorizontalOptions="Center"
                       VerticalOptions="Start" />
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSettingsTapped" />
                </Grid.GestureRecognizers>
            </Grid>

            <!-- ── Шторка 3: Формат ─────────────────────────────────────── -->
            <VerticalStackLayout x:Name="FormatSlot">
                <Grid x:Name="FormatHeader" BackgroundColor="#CC000000" Padding="16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label x:Name="FormatLabel"
                           Grid.Column="0"
                           Text="Формат: —"
                           TextColor="White"
                           FontSize="15"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           LineBreakMode="TailTruncation" />
                    <Label x:Name="FormatArrow"
                           Grid.Column="1"
                           Text="▼"
                           TextColor="#AAFFFFFF"
                           FontSize="11"
                           VerticalOptions="Center"
                           Margin="12,0,0,0" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFormatHeaderTapped" />
                    </Grid.GestureRecognizers>
                </Grid>
                <CollectionView x:Name="FormatList"
                                IsVisible="false"
                                MaximumHeightRequest="160"
                                BackgroundColor="#EE000000"
                                SelectionMode="Single"
                                SelectionChanged="OnFormatSelected"
                                ItemTemplate="{StaticResource DropdownItemTemplate}" />
            </VerticalStackLayout>

        </Grid>

        <!-- Bottom overlay: controls bar -->
        <Grid VerticalOptions="End" BackgroundColor="#CC000000" Padding="16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="4">
                <Label x:Name="ConnectionLabel"
                       Text="Не подключено"
                       TextColor="#CCFFFFFF"
                       FontSize="13" />
                <Label x:Name="StatusLabel"
                       Text="Press Start"
                       TextColor="#CCFFFFFF"
                       FontSize="13" />
                <!-- Чекбоксы. Orientation переключается из code-behind:
                     landscape → Horizontal (бок о бок), portrait → Vertical
                     (друг под другом — чтобы не наезжать на правые кнопки). -->
                <StackLayout x:Name="CheckboxRow" Orientation="Horizontal" Spacing="20">
                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                        <CheckBox x:Name="LockCheckBox"
                      CheckedChanged="OnLockCheckedChanged"
                      Color="White" />
                        <Label Text="Зафиксировать"
                   TextColor="White"
                   FontSize="13"
                   VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                        <CheckBox x:Name="PreviewCheckBox"
                      IsChecked="True"
                      CheckedChanged="OnPreviewCheckedChanged"
                      Color="White" />
                        <Label Text="Показать превью"
                   TextColor="White"
                   FontSize="13"
                   VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </StackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="8">
                <Button x:Name="ConnectBtn"
                        Text="Подключиться"
                        Clicked="OnConnectClicked"
                        FontSize="13"
                        Padding="14,6" />
                <Button x:Name="StartStopBtn"
                        Text="Start"
                        Clicked="OnStartStopClicked"
                        FontSize="15"
                        Padding="20,8" />
            </VerticalStackLayout>
        </Grid>

    </Grid>

</ContentPage>
